# ============================================================
# HCM Deck Course Agent — configuration template
# ============================================================
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` to git (already covered by .gitignore).
#
#    cp .env.example .env       # Linux / macOS / Git Bash
#    Copy-Item .env.example .env  # PowerShell
#    copy .env.example .env       # CMD
# ============================================================


# ------------------------------------------------------------
# 1. HCM Deck tenant
# ------------------------------------------------------------
# Your organisation's HCM Deck home URL. The agent lands here,
# handles SSO redirect (if Chrome already has cached credentials),
# enumerates every section and processes every course/test.
#
# Example: https://acme.hcmdeck.com/protected/home
HCM_DASHBOARD_URL=


# ------------------------------------------------------------
# 2. Chrome (Windows defaults — adjust if Chrome lives elsewhere)
# ------------------------------------------------------------
# Path to your Chrome executable. Uses your real profile so SSO
# cookies / saved logins are reused — the agent never types
# passwords. Close ALL Chrome windows before launching.
CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_USER_DATA=%LOCALAPPDATA%\Google\Chrome\User Data


# ------------------------------------------------------------
# 3. LLM provider — Azure OpenAI (RECOMMENDED)
# ------------------------------------------------------------
# Best choice when you have an Azure OpenAI / Foundry resource.
# See README -> "LLM configuration" for step-by-step deployment.
#
# Tested & recommended deployments (pick whichever is available):
#   - gpt-5-chat (2025-08-07 or 2025-10-03)  — multimodal, best for SCORM UI
#   - gpt-4o (2024-11-20)                    — proven multimodal baseline
#   - model-router-2025-11-18 (GA, newest)   — auto-routes to gpt-5-chat for vision
#
# The agent uses `AZURE_OPENAI_DEPLOYMENT` directly via Chat Completions API.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview


# ------------------------------------------------------------
# 4. Alternative LLM providers (uncomment ONE if not using Azure)
# ------------------------------------------------------------
# Anthropic Claude — strongest reasoning, native vision (~$0.05/run)
# ANTHROPIC_API_KEY=
#
# OpenAI direct — simplest path, no Azure resource needed
# OPENAI_API_KEY=
#
# Google Gemini — cheapest option (~$0.01/run), good vision
# GOOGLE_API_KEY=
#
# Note: only Azure path is wired up in agents/course_agent.py out of
# the box. To use Claude / OpenAI / Gemini, swap `create_llm()` to
# the appropriate ChatAnthropic / ChatOpenAI / ChatGoogle class from
# `browser_use`. See README -> "Switching LLM provider".
